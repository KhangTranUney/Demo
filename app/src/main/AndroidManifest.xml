<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <uses-permission
        android:name="android.permission.SEND_SMS"
        tools:ignore="SmsAndCallLogPolicy" />
    <uses-permission
        android:name="android.permission.READ_SMS"
        tools:ignore="SmsAndCallLogPolicy" />
    <uses-permission
        android:name="android.permission.RECEIVE_SMS"
        tools:ignore="SmsAndCallLogPolicy" />
    <uses-permission
        android:name="android.permission.WRITE_SMS"
        tools:ignore="SmsAndCallLogPolicy,SystemPermissionTypo" />
    <uses-permission
        android:name="android.permission.RECEIVE_MMS"
        tools:ignore="SmsAndCallLogPolicy" />
    <uses-permission
        android:name="android.permission.RECEIVE_WAP_PUSH"
        tools:ignore="SmsAndCallLogPolicy" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Demo">
        <activity
            android:name="com.example.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Demo" />

        <activity
            android:name=".sms.SmsActivity"
            android:exported="false"
            android:theme="@style/Theme.Demo" />
        <activity
            android:name=".snackbar.SnackbarActivity"
            android:exported="false"
            android:theme="@style/Theme.Demo" />

        <!-- Required component 1: SMS_DELIVER receiver -->
        <receiver
            android:name=".sms.SmsDeliverReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_DELIVER" />
            </intent-filter>
        </receiver>

        <!-- Required component 2: WAP_PUSH_DELIVER receiver -->
        <receiver
            android:name=".sms.MmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_WAP_PUSH">
            <intent-filter>
                <action android:name="android.provider.Telephony.WAP_PUSH_DELIVER" />
                <data android:mimeType="application/vnd.wap.mms-message" />
            </intent-filter>
        </receiver>

        <!-- Required component 3: respond-via-message service -->
        <service
            android:name=".sms.HeadlessSmsSendService"
            android:exported="true"
            android:permission="android.permission.SEND_RESPOND_VIA_MESSAGE">
            <intent-filter>
                <action android:name="android.intent.action.RESPOND_VIA_MESSAGE" />
                <category android:name="android.intent.category.DEFAULT" />

                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>
        </service>

        <!-- Required component 4: SENDTO activity for composing -->
        <activity
            android:name=".sms.ComposeSmsActivity"
            android:exported="true"
            android:theme="@style/Theme.Demo">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <action android:name="android.intent.action.SENDTO" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>
        </activity>

        <!--
            CustomTabActivity hosts Custom Tabs (via Chrome's CustomTabsActivity).

            When the embedded web page navigates to a custom-scheme URL (e.g.
            demoapp://callback?token=...&from=cct), Chrome fires an intent with
            FLAG_ACTIVITY_NEW_TASK to open the corresponding app handler.

            Without launchMode="singleTop", Android creates a brand-new instance
            of CustomTabActivity — triggering onCreate() again, destroying the
            old instance, and losing all its state.  The existing onNewIntent()
            override never fires.

            With launchMode="singleTop":
              - If an instance of CustomTabActivity already exists at the top of
                the task stack, Android reuses it and delivers the new intent via
                onNewIntent() instead of creating a duplicate.
              - The existing instance keeps its state; the Compose recomposition
                picks up the updated deepLinkData via the mutableStateOf.
              - If no instance exists, a new one is created normally.

            The matching intent-filter (action=VIEW, category=DEFAULT|BROWSABLE,
            data scheme=demoapp) is what Android uses to route the URL to this
            activity in the first place.
        -->
        <activity
            android:name=".customtab.CustomTabActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Demo">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="callback"
                    android:scheme="demoapp" />
            </intent-filter>
        </activity>
            <activity
            android:name="com.example.kinshield.onboarding.KSOnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.Demo" />

            <activity
            android:name="com.example.kinshield.home.KSHomeActivity"
            android:exported="false"
            android:theme="@style/Theme.Demo" />

            <activity
            android:name="com.example.kinshield.familymanagement.KSFamilyManagementActivity"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:exported="false"
            android:theme="@style/Theme.Demo" />

            <activity
            android:name="com.example.kinshield.devicesetup.KSDeviceSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.Demo" />

    </application>

</manifest>